define SILO 1155865682
define LED -246585138
define MEM -851746783

# Metals
define Iron HASH("Iron")
define ICON_Iron HASH("ItemIronOre")
define Gold HASH("Gold")
define ICON_Gold HASH("ItemGoldOre")
