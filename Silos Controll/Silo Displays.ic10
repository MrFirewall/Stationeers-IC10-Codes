define ICON_PIHydrazine HASH("ItemPureIceHydrazine")
define Coal HASH("Coal")
define ICON_Coal HASH("ItemCoalOre")

start:
sb 235638270 On 1
sb LED On 1
lbn r0 SILO Iron Quantity Average
sbn LED Iron Setting r0
sbn MEM Iron Setting ICON_Iron
lbn r0 SILO Gold Quantity Average
