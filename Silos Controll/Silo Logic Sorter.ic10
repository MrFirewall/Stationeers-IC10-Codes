# --- Coal ---
lbn r0 SORTER Coal ReferenceId Maximum
lbn r2 SILO_TYPE Coal Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Coal 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

yield
j loop