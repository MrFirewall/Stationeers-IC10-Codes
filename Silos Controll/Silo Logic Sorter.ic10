# ============================================================
# LogicSorter Filter Controller
# Setzt Filter dynamisch basierend auf Silo-Füllstand
# Wenn Silo voll -> Mode 0 (passthrough), sonst Mode 1
# Loop: evaluiert alle Filter jedes yield
# ============================================================

define SORTER 873418029
define STAPLER -2020231820
define SILO_TYPE 1155865682
define OP 1

# Maximaler Füllstand eines Silos (Standard: 580, abhängig vom Silo-Typ)
# Passe diesen Wert ggf. an deine Silo-Kapazität an!
define SILO_MAX 580

define Iron HASH("Iron")
define ICON_Iron HASH("ItemIronOre")
define Gold HASH("Gold")
define ICON_Gold HASH("ItemGoldOre")
define Copper HASH("Copper")
define ICON_Copper HASH("ItemCopperOre")
define Nickel HASH("Nickel")
define ICON_Nickel HASH("ItemNickelOre")
define Silver HASH("Silver")
define ICON_Silver HASH("ItemSilverOre")
define Lead HASH("Lead")
define ICON_Lead HASH("ItemLeadOre")
define Silicon HASH("Silicon")
define ICON_Silicon HASH("ItemSiliconOre")
define Steel HASH("Steel")
define ICON_Steel HASH("ItemSteelIngot")
define Uran HASH("Uran")
define ICON_Uran HASH("ItemUraniumOre")
define Electrum HASH("Electrum")
define ICON_Electrum HASH("ItemElectrumIngot")
define Invar HASH("Invar")
define ICON_Invar HASH("ItemInvarIngot")
define Constantan HASH("Constantan")
define ICON_Constantan HASH("ItemConstantanIngot")
define Solder HASH("Solder")
define ICON_Solder HASH("ItemSolderIngot")
define Astroloy HASH("Astroloy")
define ICON_Astroloy HASH("ItemAstroloyIngot")
define Hastelloy HASH("Hastelloy")
define ICON_Hastelloy HASH("ItemHastelloyIngot")
define Inconel HASH("Inconel")
define ICON_Inconel HASH("ItemInconelIngot")
define Stellite HASH("Stellite")
define ICON_Stellite HASH("ItemStelliteIngot")
define Waspaloy HASH("Waspaloy")
define ICON_Waspaloy HASH("ItemWaspaloyIngot")
define Cobalt HASH("Cobalt")
define ICON_Cobalt HASH("ItemCobaltOre")
define PISteam HASH("PureIceSteam")
define ICON_PISteam HASH("ItemPureIceSteam")
define PISilanol HASH("PureIceSilanol")
define ICON_PISilanol HASH("ItemPureIceSilanol")
define PIPollut HASH("PureIcePollutant")
define ICON_PIPollut HASH("ItemPureIcePollutant")
define PIOzone HASH("PureIceOzone")
define ICON_PIOzone HASH("ItemPureIceOzone")
define PIOxygen HASH("PureIceOxygen")
define ICON_PIOxygen HASH("ItemPureIceOxygen")
define PINitrous HASH("PureIceNitrous")
define ICON_PINitrous HASH("ItemPureIceNitrous")
define PINitrogen HASH("PureIceNitrogen")
define ICON_PINitrogen HASH("ItemPureIceNitrogen")
define PIVolat HASH("PureIceVolatiles")
define ICON_PIVolat HASH("ItemPureIceVolatiles")
define PIHydrogen HASH("PureIceHydrogen")
define ICON_PIHydrogen HASH("ItemPureIceHydrogen")
define PIHydrazine HASH("PureIceHydrazine")
define ICON_PIHydrazine HASH("ItemPureIceHydrazine")
define Coal HASH("Coal")
define ICON_Coal HASH("ItemCoalOre")

init:
sb SORTER On 1
sb STAPLER Setting 50
sb STAPLER On 1

loop:
# --- Iron ---
lbn r0 SORTER Iron ReferenceId Maximum
lbn r2 SILO_TYPE Iron Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Iron 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Gold ---
lbn r0 SORTER Gold ReferenceId Maximum
lbn r2 SILO_TYPE Gold Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Gold 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Copper ---
lbn r0 SORTER Copper ReferenceId Maximum
lbn r2 SILO_TYPE Copper Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Copper 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Nickel ---
lbn r0 SORTER Nickel ReferenceId Maximum
lbn r2 SILO_TYPE Nickel Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Nickel 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Silver ---
lbn r0 SORTER Silver ReferenceId Maximum
lbn r2 SILO_TYPE Silver Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Silver 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Lead ---
lbn r0 SORTER Lead ReferenceId Maximum
lbn r2 SILO_TYPE Lead Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Lead 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Silicon ---
lbn r0 SORTER Silicon ReferenceId Maximum
lbn r2 SILO_TYPE Silicon Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Silicon 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Steel ---
lbn r0 SORTER Steel ReferenceId Maximum
lbn r2 SILO_TYPE Steel Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Steel 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Uranium ---
lbn r0 SORTER Uran ReferenceId Maximum
lbn r2 SILO_TYPE Uran Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Uran 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1
lbn r2 SORTER Uran Mode 3
# --- Electrum ---
lbn r0 SORTER Electrum ReferenceId Maximum
lbn r2 SILO_TYPE Electrum Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Electrum 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Invar ---
lbn r0 SORTER Invar ReferenceId Maximum
lbn r2 SILO_TYPE Invar Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Invar 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Constantan ---
lbn r0 SORTER Constantan ReferenceId Maximum
lbn r2 SILO_TYPE Constantan Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Constantan 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Solder ---
lbn r0 SORTER Solder ReferenceId Maximum
lbn r2 SILO_TYPE Solder Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Solder 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Astroloy ---
lbn r0 SORTER Astroloy ReferenceId Maximum
lbn r2 SILO_TYPE Astroloy Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Astroloy 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Hastelloy ---
lbn r0 SORTER Hastelloy ReferenceId Maximum
lbn r2 SILO_TYPE Hastelloy Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Hastelloy 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Inconel ---
lbn r0 SORTER Inconel ReferenceId Maximum
lbn r2 SILO_TYPE Inconel Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Inconel 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Stellite ---
lbn r0 SORTER Stellite ReferenceId Maximum
lbn r2 SILO_TYPE Stellite Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Stellite 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Waspaloy ---
lbn r0 SORTER Waspaloy ReferenceId Maximum
lbn r2 SILO_TYPE Waspaloy Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Waspaloy 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- Cobalt ---
lbn r0 SORTER Cobalt ReferenceId Maximum
lbn r2 SILO_TYPE Cobalt Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_Cobalt 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- PureIce Steam ---
lbn r0 SORTER PISteam ReferenceId Maximum
lbn r2 SILO_TYPE PISteam Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_PISteam 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- PureIce Silanol ---
lbn r0 SORTER PISilanol ReferenceId Maximum
lbn r2 SILO_TYPE PISilanol Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_PISilanol 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- PureIce Pollutant ---
lbn r0 SORTER PIPollut ReferenceId Maximum
lbn r2 SILO_TYPE PIPollut Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_PIPollut 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- PureIce Ozone ---
lbn r0 SORTER PIOzone ReferenceId Maximum
lbn r2 SILO_TYPE PIOzone Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_PIOzone 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- PureIce Oxygen ---
lbn r0 SORTER PIOxygen ReferenceId Maximum
lbn r2 SILO_TYPE PIOxygen Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_PIOxygen 8
or r1 r1 OP
mul r1 r1 r4
put r0 0 r1

# --- PureIce Nitrous ---
lbn r0 SORTER PINitrous ReferenceId Maximum
lbn r2 SILO_TYPE PINitrous Quantity 3
slt r4 r2 SILO_MAX
sll r1 ICON_PINitrous 8
or r1 r1 OP
mul r1 r1 r4
