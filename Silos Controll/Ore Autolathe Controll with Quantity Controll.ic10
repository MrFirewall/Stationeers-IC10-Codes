sbn AL_TYPE IceNitrit Activate r2
lbn r0 SILO_TYPE Iron Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Iron On r1
sbn AL_TYPE Iron Activate r2
