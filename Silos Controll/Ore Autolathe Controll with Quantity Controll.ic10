slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Copper On r1
sbn AL_TYPE Copper Activate r2
lbn r0 SILO_TYPE Gold Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Gold On r1
sbn AL_TYPE Gold Activate r2
lbn r0 SILO_TYPE Silicon Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Silicon On r1
sbn AL_TYPE Silicon Activate r2
lbn r0 SILO_TYPE Coal Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Coal On r1
sbn AL_TYPE Coal Activate r2
lbn r0 SILO_TYPE Lead Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Lead On r1
sbn AL_TYPE Lead Activate r2
lbn r0 SILO_TYPE Nickel Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Nickel On r1
sbn AL_TYPE Nickel Activate r2
lbn r0 SILO_TYPE Silver Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Silver On r1
sbn AL_TYPE Silver Activate r2
lbn r0 SILO_TYPE Cobalt Quantity Sum
slt r1 r0 MAX_AMOUNT
slt r2 r0 MAX_AMOUNT_STOP
sbn AL_TYPE Cobalt On r1
sbn AL_TYPE Cobalt Activate r2
lbn r0 SILO_TYPE Uranium Quantity Sum
