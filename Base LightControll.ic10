loop:
define N_Light HASH("basis_wandleuchte_lang_breit")
define H_Light 555215790
define H_OccupancySensor 322782515
define N1_Light HASH("aufzug_eg_leicht_rund")
define H1_Light 1514476632
define H_MotionSensor -1713470563
lb r0 H_OccupancySensor Activate 3
seq r1 r0 1
